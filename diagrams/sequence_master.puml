@startuml sequence_master

skinparam backgroundColor #FAFAFA
skinparam defaultFontName Monospaced
skinparam sequenceArrowThickness 2

title modbus_c -- Master Request/Reply Sequence (Application <-> Serial)

actor Application as APP
participant "rtu_master_impl\n(Linux)" as MASTER_IMPL
participant "master.c\nRequest Builder" as MASTER
participant "Serial / TTY" as SERIAL

== Master sends request ==

APP -> MASTER_IMPL : rtu_master_rd_holding_registers(\n  addr, mem_addr, count, data)
MASTER_IMPL -> MASTER : make_request_rd_holding_registers(\n  addr, mem_addr, count, buf)
MASTER -> MASTER : validate params\nbuild ADU frame
MASTER -> MASTER : implace_crc(adu)
MASTER --> MASTER_IMPL : pointer past last byte
MASTER_IMPL -> SERIAL : write(fd, buf, len)

== Master receives reply ==

SERIAL -> MASTER_IMPL : read(fd, buf, reply_len)
MASTER_IMPL -> MASTER : parse_reply_rd_holding_registers(\n  buf, reply_len)
MASTER -> MASTER : size check\nvalid_crc()
MASTER --> MASTER_IMPL : modbus_rtu_rd_holding_registers_reply_t *
MASTER_IMPL -> MASTER_IMPL : copy data[] to caller buffer
MASTER_IMPL --> APP : data + count  (success)\nor NULL (failure)

== Error path: slave replies with exception ==

note over MASTER_IMPL, MASTER
  Master detects exception reply via find_ecode():
  [addr | fcode+0x80 | ecode | CRC]
end note

@enduml
